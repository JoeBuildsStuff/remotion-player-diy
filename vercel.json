{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/render.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/upload.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cleanup.ts": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
