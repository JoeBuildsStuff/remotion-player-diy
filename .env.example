# Copy to .env.local for local development, or set in Vercel project settings.
# See README "Deployment Modes" for the full picture.

# --- Cloud-rendering gate ----------------------------------------------------
# Master switch for the Vercel Sandbox/Blob/Cron pipeline.
# Leave both unset (or "false") for a public OSS demo deployment — the editor
# still loads, but Export/upload are disabled and the API routes return 403.
# Set both to "true" to enable cloud rendering on your own deploy.
CLOUD_RENDER_ENABLED=false
VITE_CLOUD_RENDER_ENABLED=false

# --- Required when CLOUD_RENDER_ENABLED=true ---------------------------------
# These two must match. The VITE_ copy is shipped to the browser bundle, so
# treat it as a soft gate, not real auth.
RENDER_SHARED_SECRET=replace-with-a-long-random-secret
VITE_RENDER_SHARED_SECRET=replace-with-the-same-secret

# Vercel Blob read/write token (uploads, render output, snapshot pointers).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace-with-your-token

# Bearer token for the Vercel Cron cleanup call.
CRON_SECRET=replace-with-a-different-long-random-secret

# --- Self-hosted Docker mode -------------------------------------------------
# Set to "selfhost" only for the Docker container build. Cloud-render vars
# above are ignored in that mode — see docs/self-hosting.md.
# VITE_DEPLOY_MODE=vercel
